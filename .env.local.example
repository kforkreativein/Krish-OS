# Auth gate (Step 1)
AUTH_SECRET=                # 32-byte hex: openssl rand -hex 32
DASHBOARD_PASSWORD=         # memorable password for the single-user login

# Supabase (used from Step 2 onward)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Single-user owner UUID (any UUID — used as user_id on every row)
OWNER_USER_ID=00000000-0000-0000-0000-000000000000

# LLM provider — Gemini does everything (text, JSON, audio transcription, embeddings).
GEMINI_API_KEY=
# Optional overrides:
# GEMINI_MODEL=gemini-2.5-flash
# GEMINI_EMBED_MODEL=gemini-embedding-001

# Telegram capture bot (Step 2)
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=        # openssl rand -hex 16
TELEGRAM_USER_ID=               # your numeric Telegram user id (via @userinfobot)

# Top rail identity (Step 3)
NEXT_PUBLIC_OWNER_NAME=Krish
NEXT_PUBLIC_OWNER_LOCATION=Earth
NEXT_PUBLIC_OWNER_ROLE=Founder

# Calendar (Step 3)
GOOGLE_CALENDAR_ICAL_URL=       # secret ical URL from Google Calendar settings

# Finance cron (Step 7)
CRON_SECRET=                            # any random string; sent as Bearer to /api/finance/snapshot
GOOGLE_SHEETS_FILE_ID=                  # Google Drive file ID of the finance workbook
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_SERVICE_ACCOUNT_KEY=             # PEM-encoded, with \n as escape for newlines
